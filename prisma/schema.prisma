generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}








datasource db {
  provider = "sqlite"
}








model User {
  id    String @id @default(uuid())
  email String @unique
  name  String
  trips Trip[]
}








model Trip {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  name        String
  startDate   DateTime
  endDate     DateTime
  description String?
  isPublic    Boolean         @default(false)
  stops       Stop[]
  checklists  ChecklistItem[]
  notes       Note[]
}








model Stop {
  id         String     @id @default(uuid())

